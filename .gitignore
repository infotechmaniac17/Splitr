# ===========================================================================
# Splitr — .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Secrets & environment
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.cache/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Node / JS / TS
# ---------------------------------------------------------------------------
node_modules/
.next/
.expo/
dist/
out/
.turbo/
*.tsbuildinfo
.pnp
.pnp.js

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/

# ---------------------------------------------------------------------------
# Storage (local dev uploads — never commit raw PDFs)
# Anchored to the runtime upload dir only; unanchored "storage/" previously
# also matched backend/app/storage/ (the PdfStorage source package) and
# silently excluded it from every commit.
# ---------------------------------------------------------------------------
backend/storage/

# ---------------------------------------------------------------------------
# OS / Editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Logs & temp files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
tmp/
temp/

# Personal invoice PDFs used for local extraction testing — never commit
Amazon Bills/
