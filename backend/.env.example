# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Database (PostgreSQL 15+)
# Format: postgresql+psycopg://user:password@host:port/dbname
# Matches the `db` service in docker-compose.yml when running locally.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://splitr:splitr@localhost:5432/splitr

# ---------------------------------------------------------------------------
# Redis 7 — Celery broker + result backend, and app-level cache
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ---------------------------------------------------------------------------
# LLM providers (PDF extraction pipeline — M3+)
# Set only the key(s) for the provider(s) you use.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Object storage (PDF uploads — M3+)
# Use any S3-compatible store (AWS S3, GCS with interop, MinIO, etc.)
# ---------------------------------------------------------------------------
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Local filesystem fallback for PdfStorage when OBJECT_STORAGE_BUCKET is
# unset (dev/tests — see app/storage/__init__.py). Ignored by git (root
# .gitignore's `storage/` entry).
PDF_STORAGE_DIR=storage/pdfs
